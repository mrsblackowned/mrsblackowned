# Stripe Public Key (frontend - safe to expose)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# Stripe Secret Key (backend only - never expose)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Resend API Key — for sending the download link email after purchase
# Sign up free at resend.com, verify your domain, then paste the key here.
RESEND_API_KEY=re_your_api_key_here

# Your email address — gets a sale notification every time someone purchases
BUSINESS_EMAIL=you@yourdomain.com
